{
        "name": "ai-flume",
        "private": true,
        "version": "0.0.1",
        "description": "Formatting tooling for ai-flume",
        "packageManager": "pnpm@10.0.0",
        "scripts": {
                    "format": "pnpm prettier:write",
                    "format:check": "pnpm prettier:check",
                    "lint": "pnpm format:check",
                    "check": "pnpm lint && terraform fmt -check -recursive",
                    "prettier:check": "prettier --check \"dashboard/**/*.{js,css,html}\" \".github/workflows/**/*.{yml,yaml}\" \"docs/**/*.md\"",
                    "prettier:write": "prettier --write \"dashboard/**/*.{js,css,html}\" \".github/workflows/**/*.{yml,yaml}\" \"docs/**/*.md\""
        },
        "devDependencies": {
                    "prettier": "^3.6.2"
        }
}
